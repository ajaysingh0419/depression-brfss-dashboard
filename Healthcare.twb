      <aliases enabled='yes' />
      <column caption='Sex Gap' datatype='real' name='[Calculation_2551356421910529]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [Year] : AVG(IF [breakout]=&apos;Female&apos; THEN [value] END)}&#10;- {FIXED [Year] : AVG(IF [breakout]=&apos;Male&apos; THEN [value] END)}' />
      </column>
      <column caption='Pct Unreliable' datatype='real' name='[Calculation_2551356422041602]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(INT(NOT [reliable])) / COUNT([value])' />
      </column>
      <column caption='Show Selected Breakout' datatype='boolean' name='[Calculation_2551356422221827]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[breakout_category] = [Parameters].[Parameter 1]' />
      </column>
      <column caption='Change 2011 to 2024' datatype='real' name='[Calculation_2551356464009222]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [state] : MAX(IF [Year]=2024 AND [breakout]=&apos;Overall&apos; AND [reliable] THEN [value] END)}&#10;- {FIXED [state] : MAX(IF [Year]=2011 AND [breakout]=&apos;Overall&apos; AND [reliable] THEN [value] END)}' />
      </column>
